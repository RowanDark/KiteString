{
  "openapi": "3.0.0",
  "info": {"title": "Test API v3", "version": "1.0"},
  "paths": {
    "/items": {
      "get": {
        "parameters": [
          {"name": "page",   "in": "query",  "schema": {"type": "integer"}, "required": false},
          {"name": "active", "in": "query",  "schema": {"type": "boolean"}, "required": false},
          {"name": "tag",    "in": "query",  "schema": {"type": "string"},  "required": false}
        ]
      },
      "post": {
        "parameters": [
          {"name": "X-API-Key", "in": "header", "schema": {"type": "string"}, "required": true}
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "name":  {"type": "string"},
                  "price": {"type": "number"},
                  "id":    {"type": "string", "format": "uuid"}
                },
                "required": ["name"]
              }
            }
          }
        }
      }
    },
    "/orders/{orderId}": {
      "get": {
        "parameters": [
          {"name": "orderId", "in": "path", "schema": {"type": "string", "format": "uuid"}, "required": true}
        ]
      }
    }
  }
}
